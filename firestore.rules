rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Role helpers — read from /userRoles/{uid} ─────────────────────
    function getUserRole() {
      return get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isReceptionist() {
      return isAuthenticated() && getUserRole() == 'receptionist';
    }

    function isPharmacist() {
      return isAuthenticated() && getUserRole() == 'pharmacist';
    }

    function isDoctor() {
      return isAuthenticated() && getUserRole() == 'doctor';
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() in ['admin', 'receptionist', 'pharmacist', 'doctor'];
    }

    function isDeskStaff() {
      return isAuthenticated() && getUserRole() in ['admin', 'receptionist'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── User Roles collection ─────────────────────────────────────────
    // Any authenticated user can read/write — safe because only
    // hospital staff have Firebase Auth accounts (no public signup).
    // The roles page in the admin panel restricts who can access it at app level.
    match /userRoles/{uid} {
      allow read, write: if request.auth != null;
    }

    // ── Public hospital content ───────────────────────────────────────
    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if isAdmin();
      match /schedule/{scheduleId} {
        allow read: if true;
        allow write: if isAdmin() || isDoctor();
      }
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    match /news/{articleId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /insurancePlans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // ── Reviews ───────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if true;   // Anyone can submit (via WhatsApp link, no login needed)
      allow update, delete: if isAdmin();
    }

    // ── Patient data ──────────────────────────────────────────────────
    match /patients/{patientId} {
      allow read: if isOwner(patientId) || isDeskStaff() || isDoctor();
      allow create: if isAuthenticated() && (request.auth.uid == patientId || isAdmin());
      allow update: if isOwner(patientId) || isDeskStaff() || isAdmin();
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isDeskStaff() || isDoctor() ||
        (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow create: if true;
      allow update: if isDeskStaff() || isDoctor() ||
        (isAuthenticated() && resource.data.patientId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'cancellationReason', 'cancelledAt', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ── Desk operations ───────────────────────────────────────────────
    match /inpatientCards/{cardId} {
      allow read: if isDeskStaff() || isDoctor();
      allow create, update: if isDeskStaff();
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isDeskStaff() || isPharmacist();
      allow create, update: if isDeskStaff() || isPharmacist();
      allow delete: if isAdmin();
    }

    match /wishCampaigns/{campaignId} {
      allow read: if isDeskStaff();
      allow create: if isDeskStaff();
      allow update, delete: if isAdmin();
    }

    // ── Queue system ──────────────────────────────────────────────────
    match /queue/{dateKey} {
      match /config/{docId} {
        allow read: if true;   // Public — TV display and patient check page
        allow write: if isDeskStaff() || isDoctor();
      }
      match /tokens/{tokenId} {
        allow read: if isDeskStaff() || isDoctor() || isAuthenticated();
        allow create: if isDeskStaff();
        allow update: if isDeskStaff() || isDoctor();
        allow delete: if isAdmin();
      }
    }

    match /counters/{counterId} {
      allow read, write: if isStaff();
    }

    // ── Pharmacy ──────────────────────────────────────────────────────
    match /medicines/{medicineId} {
      allow read: if isPharmacist() || isAdmin();
      allow create, update: if isPharmacist() || isAdmin();
      allow delete: if isAdmin();
    }

    match /stockMovements/{movementId} {
      allow read: if isPharmacist() || isAdmin();
      allow create: if isPharmacist() || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if isPharmacist() || isAdmin();
      allow create, update: if isPharmacist() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Messaging & forms ─────────────────────────────────────────────
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isDeskStaff();
    }

    match /newsletters/{subId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /jobApplications/{appId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Public creates (API routes run server-side without user auth) ────
    // These collections need unauthenticated create from API routes
    match /appointments/{id} {
      allow create: if true;   // Website booking form
      allow read, update, delete: if request.auth != null;
    }
    match /reviews/{id} {
      allow create: if true;   // WhatsApp review link (no login)
      allow read, update, delete: if request.auth != null;
    }
    match /contactMessages/{id} {
      allow create: if true;   // Contact form (no login)
      allow read, update, delete: if request.auth != null;
    }

    // ── Catch-all — any authenticated user for unlisted collections ────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
