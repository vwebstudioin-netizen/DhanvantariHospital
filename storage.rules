rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.auth.token.admin == true || request.auth.token.staff == true);
    }
    match /resumes/{fileName} {
      allow write: if true;
      allow read: if request.auth != null && 
        (request.auth.token.admin == true || request.auth.token.staff == true);
    }
  }
}
