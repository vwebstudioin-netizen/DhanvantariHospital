rules_version = '2';

/**
 * Storage Rules — Dhanvantari Hospital
 *
 * Note: Firebase Storage rules cannot read Firestore documents.
 * Roles are managed in Firestore (/userRoles/{uid}), but Storage
 * rules can only check request.auth.token (JWT claims).
 *
 * Since we use Firestore-based roles (no custom JWT claims), we use
 * simple authentication checks here. Access control is enforced at
 * the application layer — only staff accounts exist in Firebase Auth.
 */
service firebase.storage {
  match /b/{bucket}/o {

    // Any authenticated user (all are hospital staff — no public sign-up)
    function isSignedIn() {
      return request.auth != null;
    }

    // Patient owns their folder
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── Public assets ─────────────────────────────────────────────────

    // Hospital images — departments, services, gallery (public read)
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Doctor profile photos
    match /doctors/{fileName} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Gallery
    match /gallery/{fileName} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Blog images
    match /blog/{fileName} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Logo and public static assets
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Staff-only uploads ────────────────────────────────────────────

    // In-patient card prints / invoice PDFs
    match /documents/{fileName} {
      allow read, write: if isSignedIn();
    }

    // Pharmacy purchase orders and supplier invoices
    match /pharmacy/{fileName} {
      allow read, write: if isSignedIn();
    }

    // ── Patient documents ─────────────────────────────────────────────

    // Lab reports, prescriptions — patient uploads their own, staff reads
    match /patients/{patientId}/{fileName} {
      allow read: if isSignedIn() || isOwner(patientId);
      allow write: if isOwner(patientId) || isSignedIn();
    }

    // ── Job applications ──────────────────────────────────────────────

    // Resumes — public upload (applicants), authenticated read (admin)
    match /resumes/{fileName} {
      allow write: if true;
      allow read: if isSignedIn();
    }
  }
}
